# Copy to .env (gitignored) and fill in. Never commit the real .env.
# Every value here can also be set in the MCP host's server `env` block instead.

# --- LLM connection -----------------------------------------------------------
# provider: litellm (default) or openai. Both speak the OpenAI API; the only
# difference is intent/labeling. Point BASE_URL/API_KEY at any OpenAI-compatible
# endpoint (your LiteLLM proxy, or e.g. an Anthropic OpenAI-compat URL).
LLM_PROVIDER=litellm
LLM_BASE_URL=                 # e.g. https://litellm.<host>/v1   (LITELLM_BASE_URL still works as an alias)
LLM_API_KEY=                  # proxy key                        (LITELLM_API_KEY still works as an alias)
LLM_CHAT_MODEL=eagle-nothink  # tool-calling + guided-JSON model (must be non-thinking)
LLM_EMBED_MODEL=jina          # embeddings model (semantic search)

# When run as an MCP server, allow plain-chat calls to use the HOST's model
# (Claude, via Claude Code) through MCP sampling. Tool-calling / guided-JSON /
# embeddings always use the provider above. Set to false to stay fully local.
LLM_ALLOW_HOST_SAMPLING=true

# --- Web search (web-researcher subagent) -------------------------------------
# Brave Search API. https://brave.com/search/api
BRAVE_API_KEY=

# --- Optional overrides -------------------------------------------------------
# COOKBOOK_DB_PATH=           # absolute path to the sqlite DB (default: data/db/cookbook.sqlite)
# COOKBOOK_MCP_TRANSPORT=stdio  # stdio (Claude Code/Desktop) | http (Olares)
# COOKBOOK_MCP_HOST=127.0.0.1
# COOKBOOK_MCP_PORT=8000
# COOKBOOK_MCP_AUTH_TOKEN=     # if set, the http transport requires `Authorization: Bearer <token>`
