# NOTE: the Docker build context is the REPO ROOT, and this file must be at
# the repo root to take effect (Docker only reads <context>/.dockerignore).
# A symlink or copy of this file to /Users/trevest/Developer/weightloss/.dockerignore
# is what Docker actually consults. Keep them in sync.

# --- Version control / tooling ---
.git
.gitignore
*.md

# --- The Swift native app (not part of the Python image) ---
app/

# --- Python build / cache cruft ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# --- Local dev / editor ---
.DS_Store
.idea/
.vscode/
*.log

# --- Data: exclude everything under data/ EXCEPT the seed DB ---------------
# We ship ONLY the ~4.4MB seed DB (data/db/cookbook.sqlite) via an explicit
# COPY in the Dockerfile. Uploaded PDFs (data/uploads) and raw source PDFs
# (data/raw) must NOT bloat the image / leak into it.
data/
!data/db/
data/db/*
!data/db/cookbook.sqlite
