# NOTE: the Docker build context is the REPO ROOT, so this file lives at the
# repo root (Docker only reads <context>/.dockerignore).

# --- Version control / tooling ---
.git
.gitignore
*.md

# --- The Swift native app (not part of the Python image) ---
app/

# --- Python build / cache cruft ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# --- Local dev / editor ---
.DS_Store
.idea/
.vscode/
*.log

# --- Data: never ship the runtime data dir ---------------------------------
# The seed DB ships from deploy/seed/cookbook.sqlite (a committed snapshot), NOT
# from here. Uploaded PDFs (data/uploads) and raw source PDFs (data/raw) must
# never bloat the image or leak into it.
data/
